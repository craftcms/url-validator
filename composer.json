{
    "name": "craftcms/url-validator",
    "description": "Validate URLs and IP addresses against SSRF, DNS rebinding, and cloud-metadata attacks.",
    "keywords": [
        "craftcms",
        "ssrf",
        "url",
        "ip",
        "validation",
        "security"
    ],
    "homepage": "https://github.com/craftcms/url-validator",
    "license": "MIT",
    "authors": [
        {
            "name": "Pixel & Tonic",
            "homepage": "https://pixelandtonic.com/"
        }
    ],
    "require": {
        "php": "^8.0.2",
        "ext-filter": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "nunomaduro/collision": "^8.1",
        "phpstan/phpstan": "^2.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "CraftCms\\UrlValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CraftCms\\UrlValidator\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
